{
  "id": "astrcode-agent-tools",
  "name": "Agent Tools",
  "version": "0.1.0",
  "description": "Subagent delegation tools",
  "astrcode_version": "0.1.0",
  "library": "astrcode_extension_agent_tools.dll",
  "subscriptions": [
    { "event": "prompt_build", "mode": "blocking", "priority": 0 }
  ],
  "tools": [
    {
      "name": "agent",
      "description": "Spawn a subagent to handle one delegated task. Choose subagent_type from the Agents section.",
      "parameters": {
        "type": "object",
        "properties": {
          "description": { "type": "string", "description": "Short 3-5 word description of what this agent will do" },
          "prompt": { "type": "string", "description": "Task for the subagent" },
          "subagent_type": { "type": "string", "description": "Agent name from agents/ directory" },
          "mode": { "type": "string", "enum": ["single"], "default": "single" }
        },
        "required": ["prompt", "description"]
      }
    }
  ]
}
