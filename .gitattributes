# Enforce LF line endings for source files. Prevents CI format failures.
*.rs text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.exe binary
*.dll binary
*.pdb binary
