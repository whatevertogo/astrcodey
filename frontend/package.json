{
  "name": "astrcode-desktop",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run prepare:sidecar && cd .. && node frontend/node_modules/@tauri-apps/cli/tauri.js dev",
    "tauri:build": "npm run prepare:sidecar -- --release && cd .. && node frontend/node_modules/@tauri-apps/cli/tauri.js build",
    "prepare:sidecar": "node scripts/prepare-sidecar.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test:contract": "esbuild src/services/protocol.ts --bundle --format=esm --outfile=../target/frontend-contract/services/protocol.js && node scripts/protocol-contract.test.mjs",
    "test:dev-server": "node scripts/dev-server.test.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:contract"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.25",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-http": "^2.5.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^8.0.11"
  }
}
